" Disable old vi compatibility
set nocompatible

" Modules
source ~/.vim/core/settings.vim
source ~/.vim/core/indent.vim
source ~/.vim/core/keymaps.vim
source ~/.vim/plugins/plugins.vim
source ~/.vim/core/ui.vim
source ~/.vim/core/autocmds.vim
source ~/.vim/plugins/markdown.vim
source ~/.vim/plugins/writing.vim
source ~/.vim/plugins/orgmode.vim
source ~/.vim/plugins/snippets.vim
source ~/.vim/plugins/data.vim
